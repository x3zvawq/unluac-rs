{
  "name": "unluac-js",
  "version": "0.1.0",
  "private": true,
  "description": "JavaScript wrapper package for the unluac WebAssembly build.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/X3ZvaWQ/unluac-rs.git",
    "directory": "packages/unluac-js"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "tsdown": "0.21.7",
    "typescript": "6.0.2"
  }
}
